@inherits LayoutComponentBase

<div class="page">
    <div class="sidebar">
        <NavMenu />
    </div>

    <main>
        <div class="top-row px-4">
            <span class="top-row-brand">
                <span class="top-brand-social">Social</span><span class="top-brand-videotor">Videotor</span>
            </span>
            <span class="top-row-tagline">AI-powered social media video clips</span>
        </div>

        <article class="content px-4">
            @Body
        </article>
    </main>
</div>

<div id="blazor-error-ui" data-nosnippet>
