@page "/upload-video"
@using SocialVideotor.Models
@using SocialVideotor.Services
@inject IRawClipService RawClipService
@inject IHttpClientFactory HttpClientFactory
@inject IHttpContextAccessor HttpContextAccessor
@inject IJSRuntime JS
@inject NavigationManager NavigationManager
@rendermode InteractiveServer
@implements IDisposable

<PageTitle>Raw Clips - SocialVideotor</PageTitle>

<FluentStack Orientation="Orientation.Vertical" Style="gap: 24px; max-width: 900px; margin: 0 auto;">

    <FluentStack Orientation="Orientation.Horizontal" VerticalAlignment="VerticalAlignment.Center" Style="gap: 12px;">
        <FluentButton Appearance="Appearance.Outline" OnClick="@GoBack">
            <FluentIcon Value="@(new Icons.Regular.Size20.ArrowLeft())" />
        </FluentButton>
        <div>
            <h2 style="margin: 0;">✂️ Generate Raw Clips</h2>
            <p style="margin: 4px 0 0 0; color: var(--neutral-foreground-hint); font-size: 0.85rem;">
                Upload an MP4 and get 5–10 short vertical clips (9:16) — no text, no music, clean cuts.
            </p>
        </div>
    </FluentStack>

    @if (phase == Phase.Idle)
    {
        <FluentCard Style="padding: 32px; width: 100%;">
            <FluentStack Orientation="Orientation.Vertical" Style="gap: 20px;">

                <div style="border: 2px dashed var(--neutral-stroke-rest); border-radius: 12px; padding: 40px; text-align: center;">
                    <FluentIcon Value="@(new Icons.Regular.Size48.Video())" Style="color: var(--accent-fill-rest);" />
                    <p style="margin: 12px 0 4px 0; font-size: 1rem; font-weight: 600;">
                        @(selectedFile == null ? "Select an MP4 file" : selectedFile.Name)
                    </p>
                    @if (selectedFile != null)
                    {
                        <p style="margin: 0 0 12px 0; color: var(--neutral-foreground-hint); font-size: 0.85rem;">
                            @FormatFileSize(selectedFile.Size)
                        </p>
                    }
                    <label style="cursor: pointer; display: inline-block;">
                        <InputFile id="raw-video-file" OnChange="@OnFileSelected" accept=".mp4" style="display: none;" />
                        <FluentButton Appearance="Appearance.Outline" Style="pointer-events: none;">
                            <FluentIcon Value="@(new Icons.Regular.Size20.FolderOpen())" Slot="start" />
                            @(selectedFile == null ? "Browse Files" : "Change File")
                        </FluentButton>
                    </label>
                    <p style="color: var(--neutral-foreground-hint); font-size: 0.78rem; margin: 8px 0 0 0;">
                        MP4 only · Max 500 MB
                    </p>
                </div>

                @if (!string.IsNullOrEmpty(errorMessage))
                {
                    <FluentMessageBar Intent="MessageIntent.Error">@errorMessage</FluentMessageBar>
                }

                <FluentStack Orientation="Orientation.Horizontal" Style="gap: 12px; justify-content: flex-end;">
                    <FluentButton Appearance="Appearance.Outline" OnClick="@GoBack">Cancel</FluentButton>
                    <FluentButton Appearance="Appearance.Accent" OnClick="@StartUpload" Disabled="@(selectedFile == null)">
                        <FluentIcon Value="@(new Icons.Regular.Size20.Play())" Slot="start" />
                        Generate Clips
                    </FluentButton>
                </FluentStack>

            </FluentStack>
        </FluentCard>
    }

    @if (phase == Phase.Uploading || phase == Phase.Processing)
    {
        <FluentCard Style="padding: 32px; width: 100%;">
            <FluentStack Orientation="Orientation.Vertical" Style="gap: 20px; align-items: center; text-align: center;">
                <FluentProgressRing Style="width: 64px; height: 64px;" />
                <div>
                    <h3 style="margin: 0;">@(currentJob?.StatusMessage ?? "Working…")</h3>
                    <p style="margin: 4px 0 0 0; color: var(--neutral-foreground-hint); font-size: 0.85rem;">
                        @(phase == Phase.Uploading ? "Uploading your video…" : "Splitting into vertical clips…")
                    </p>
                </div>
                @if (currentJob != null && currentJob.ProgressPercent > 0)
                {
                    <div style="width: 100%; max-width: 400px;">
                        <FluentProgress Value="@currentJob.ProgressPercent" Max="100" />
                        <p style="margin: 4px 0 0 0; font-size: 0.8rem; color: var(--neutral-foreground-hint);">
                            @currentJob.ProgressPercent%
                        </p>
                    </div>
                }
            </FluentStack>
        </FluentCard>
    }

    @if (phase == Phase.Done && currentJob != null)
    {
        @if (!currentJob.FfmpegAvailable)
        {
            <FluentMessageBar Intent="MessageIntent.Warning">
                <b>FFmpeg not found.</b> Preview shows time-range sections of the original video.
                Install FFmpeg on the server to generate individually downloadable 9:16 clips.
            </FluentMessageBar>
        }

        <FluentCard Style="padding: 20px; width: 100%;">
            <FluentStack Orientation="Orientation.Vertical" Style="gap: 16px;">
                <FluentStack Orientation="Orientation.Horizontal" VerticalAlignment="VerticalAlignment.Center" Style="justify-content: space-between;">
                    <h3 style="margin: 0;">
                        🎬 @currentJob.Clips.Count Clips — @currentJob.SourceFileName
                        <span style="font-weight: 400; font-size: 0.85rem; color: var(--neutral-foreground-hint);">
                            (source: @FormatDuration(currentJob.VideoDurationSeconds))
                        </span>
                    </h3>
                    <FluentStack Orientation="Orientation.Horizontal" Style="gap: 8px;">
                        <span style="font-size: 0.8rem; color: var(--neutral-foreground-hint); align-self: center;"
                              aria-label="Auto-deletion time">
                            <FluentIcon Value="@(new Icons.Regular.Size16.Timer())" />
                            Auto-deletes @currentJob.ExpiresAtUtc.ToLocalTime().ToString("MMM d, h:mm tt")
                        </span>
                        <FluentButton Appearance="Appearance.Outline" OnClick="@DeleteJob">
                            <FluentIcon Value="@(new Icons.Regular.Size20.Delete())" Slot="start" />
                            Delete
                        </FluentButton>
                        <FluentButton Appearance="Appearance.Outline" OnClick="@Reset">
                            <FluentIcon Value="@(new Icons.Regular.Size20.ArrowCounterclockwise())" Slot="start" />
                            Upload Another
                        </FluentButton>
                    </FluentStack>
                </FluentStack>

                <FluentStack Orientation="Orientation.Horizontal" VerticalAlignment="VerticalAlignment.Center" Style="justify-content: space-between; gap: 12px; flex-wrap: wrap;">
                    <FluentStack Orientation="Orientation.Horizontal" VerticalAlignment="VerticalAlignment.Center" Style="gap: 8px;">
                        <FluentLabel>Export Format</FluentLabel>
                        <FluentSelect TOption="string" @bind-Value="exportFormat" Style="width: 180px;">
                            <FluentOption Value="vertical">Vertical (9:16)</FluentOption>
                            <FluentOption Value="square">Square (1:1)</FluentOption>
                        </FluentSelect>
                    </FluentStack>
                    <FluentStack Orientation="Orientation.Horizontal" VerticalAlignment="VerticalAlignment.Center" Style="gap: 8px; flex-wrap: wrap;">
                        <FluentButton Appearance="Appearance.Outline" OnClick="@SelectAllClips">Select All</FluentButton>
                        <FluentButton Appearance="Appearance.Outline" OnClick="@ClearSelectedClips">Clear Selection</FluentButton>
                        @if (HasSelectedClips())
                        {
                            <a href="@GetSelectedDownloadUrl()" download="@GetSelectedZipFileName()" style="text-decoration: none;">
                                <FluentButton Appearance="Appearance.Accent">
                                    <FluentIcon Value="@(new Icons.Regular.Size20.ArrowDownload())" Slot="start" />
                                    Download Selected (@GetSelectedClipCount())
                                </FluentButton>
                            </a>
                        }
                        else
                        {
                            <FluentButton Appearance="Appearance.Accent" Disabled="true">
                                <FluentIcon Value="@(new Icons.Regular.Size20.ArrowDownload())" Slot="start" />
                                Download Selected (0)
                            </FluentButton>
                        }
                    </FluentStack>
                </FluentStack>
                <span style="font-size: 0.8rem; color: var(--neutral-foreground-hint);">
                    Batch export is all-or-nothing. If one selected clip fails to export, no ZIP is returned.
                </span>

                <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(240px, 1fr)); gap: 16px;">
                    @foreach (var clip in currentJob.Clips)
                    {
                        <FluentCard Style="padding: 0; overflow: hidden;">
                            <FluentStack Orientation="Orientation.Vertical" Style="gap: 0;">
                                <div style="background: #000; aspect-ratio: 9/16; max-height: 360px; overflow: hidden; display: flex; align-items: center; justify-content: center;">
                                    <video controls preload="metadata"
                                           style="width: 100%; height: 100%; object-fit: contain;"
                                           src="@clip.PreviewUrl">
                                        Your browser does not support the video element.
                                    </video>
                                </div>
                                <FluentStack Orientation="Orientation.Vertical" Style="gap: 8px; padding: 12px;">
                                    <FluentStack Orientation="Orientation.Horizontal" VerticalAlignment="VerticalAlignment.Center" Style="justify-content: space-between;">
                                        <FluentStack Orientation="Orientation.Horizontal" VerticalAlignment="VerticalAlignment.Center" Style="gap: 8px;">
                                            <FluentCheckbox Value="@IsClipSelected(clip)" ValueChanged="@((selected) => SetClipSelection(clip, selected))" />
                                            <span style="font-weight: 600;">Clip @clip.ClipNumber</span>
                                        </FluentStack>
                                        <FluentBadge Appearance="Appearance.Accent">@FormatDuration(clip.DurationSeconds)</FluentBadge>
                                    </FluentStack>
                                    <span style="font-size: 0.8rem; color: var(--neutral-foreground-hint);">
                                        @FormatTime(clip.StartTimeSeconds) – @FormatTime(clip.EndTimeSeconds)
                                    </span>
                                    <span style="font-size: 0.78rem; color: var(--neutral-foreground-hint);">
                                        @GetExportFileName(clip)
                                    </span>
                                    <a href="@GetIndividualDownloadUrl(clip)" download="@GetExportFileName(clip)" style="text-decoration: none;">
                                        <FluentButton Appearance="Appearance.Outline" Style="width: 100%;">
                                            <FluentIcon Value="@(new Icons.Regular.Size20.ArrowDownload())" Slot="start" />
                                            Download @GetExportFormatLabel()
                                        </FluentButton>
                                    </a>
                                </FluentStack>
                            </FluentStack>
                        </FluentCard>
                    }
                </div>
            </FluentStack>
        </FluentCard>
    }

    @if (phase == Phase.Failed)
    {
        <FluentCard Style="padding: 32px; width: 100%;">
            <FluentStack Orientation="Orientation.Vertical" Style="gap: 16px; align-items: center; text-align: center;">
                <FluentIcon Value="@(new Icons.Regular.Size48.ErrorCircle())" Style="color: var(--error-foreground);" />
                <div>
                    <h3 style="margin: 0;">Processing Failed</h3>
                    <p style="margin: 8px 0 0 0; color: var(--neutral-foreground-hint);">@currentJob?.ErrorMessage</p>
                </div>
                <FluentStack Orientation="Orientation.Horizontal" Style="gap: 8px;">
                    <FluentButton Appearance="Appearance.Accent" OnClick="@Retry">Retry</FluentButton>
                    <FluentButton Appearance="Appearance.Outline" OnClick="@Reset">Reset</FluentButton>
                </FluentStack>
            </FluentStack>
        </FluentCard>
    }

</FluentStack>

@code {
    private enum Phase { Idle, Uploading, Processing, Done, Failed }

    private Phase phase = Phase.Idle;
    private IBrowserFile? selectedFile;
    private RawClipJob? currentJob;
    private string errorMessage = string.Empty;
    private Timer? pollingTimer;
    private int _pollInProgress; // 0 = idle, 1 = executing; prevents overlapping callbacks
    private readonly HashSet<string> selectedClipIds = new(StringComparer.Ordinal);
    private string exportFormat = "vertical";

    private void OnFileSelected(InputFileChangeEventArgs e)
    {
        errorMessage = string.Empty;
        selectedFile = e.File;
    }

    private async Task StartUpload()
    {
        if (selectedFile == null) return;

        const long maxSize = 500L * 1024 * 1024; // 500 MB
        if (selectedFile.Size > maxSize)
        {
            errorMessage = "File exceeds the 500 MB limit.";
            return;
        }

        errorMessage = string.Empty;
        phase = Phase.Uploading;
        StateHasChanged();

        try
        {
            var client = HttpClientFactory.CreateClient();
            client.BaseAddress = new Uri(NavigationManager.BaseUri);

            var initiateResponse = await client.PostAsJsonAsync("/api/uploads/initiate", new UploadInitiateRequest
            {
                FileName = selectedFile.Name,
                FileSize = selectedFile.Size,
                ContentType = selectedFile.ContentType
            });

            if (!initiateResponse.IsSuccessStatusCode)
            {
                var initiateError = await initiateResponse.Content.ReadAsStringAsync();
                if (initiateResponse.StatusCode == System.Net.HttpStatusCode.BadRequest &&
                    initiateError.Contains("Direct upload is not configured.", StringComparison.OrdinalIgnoreCase))
                {
                    await UploadViaServerAsync(client);
                    return;
                }

                throw new InvalidOperationException(initiateError);
            }

            var initiatePayload = await initiateResponse.Content.ReadFromJsonAsync<UploadInitiateResponse>();
            if (initiatePayload == null)
                throw new InvalidOperationException("Could not initiate upload.");

            await JS.InvokeVoidAsync(
                "socialVideotorUpload.uploadSelectedFile",
                "raw-video-file",
                initiatePayload.UploadUrl,
                string.IsNullOrWhiteSpace(selectedFile.ContentType) ? "video/mp4" : selectedFile.ContentType);

            var completeResponse = await client.PostAsJsonAsync("/api/uploads/complete", new UploadCompleteRequest
            {
                JobId = initiatePayload.JobId,
                BlobName = initiatePayload.BlobName
            });

            if (!completeResponse.IsSuccessStatusCode)
                throw new InvalidOperationException(await completeResponse.Content.ReadAsStringAsync());

            currentJob = await completeResponse.Content.ReadFromJsonAsync<RawClipJob>();
            if (currentJob == null)
                throw new InvalidOperationException("Upload completed but no job was returned.");
            StartPolling();
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
            phase = Phase.Idle;
        }
    }

    private async Task UploadViaServerAsync(HttpClient client)
    {
        if (selectedFile == null)
            throw new InvalidOperationException("No file selected.");

        await using var stream = selectedFile.OpenReadStream(500L * 1024 * 1024);
        using var fileContent = new StreamContent(stream);
        fileContent.Headers.TryAddWithoutValidation(
            "Content-Type",
            string.IsNullOrWhiteSpace(selectedFile.ContentType) ? "video/mp4" : selectedFile.ContentType);

        using var form = new MultipartFormDataContent
        {
            { fileContent, "file", selectedFile.Name }
        };

        var uploadResponse = await client.PostAsync("/api/jobs/upload", form);
        if (!uploadResponse.IsSuccessStatusCode)
            throw new InvalidOperationException(await uploadResponse.Content.ReadAsStringAsync());

        currentJob = await uploadResponse.Content.ReadFromJsonAsync<RawClipJob>();
        if (currentJob == null)
            throw new InvalidOperationException("Upload completed but no job was returned.");

        StartPolling();
    }

    private void StartPolling()
    {
        pollingTimer = new Timer(async _ =>
        {
            // Prevent overlapping callbacks when processing takes longer than the interval
            if (Interlocked.CompareExchange(ref _pollInProgress, 1, 0) != 0) return;
            try
            {
                if (currentJob == null) return;
                var job = RawClipService.GetJob(currentJob.Id);
                if (job == null) return;
                if (!string.Equals(job.UserId, GetCurrentUserId(), StringComparison.OrdinalIgnoreCase))
                {
                    await InvokeAsync(() =>
                    {
                        errorMessage = "Job is not accessible for the current user.";
                        StopPolling();
                        phase = Phase.Idle;
                        StateHasChanged();
                    });
                    return;
                }

                await InvokeAsync(() =>
                {
                    currentJob = job;
                    SyncSelectedClips();
                    phase = job.Status switch
                    {
                        RawClipJobStatus.Uploading => Phase.Uploading,
                        RawClipJobStatus.Queued => Phase.Processing,
                        RawClipJobStatus.Processing => Phase.Processing,
                        RawClipJobStatus.Ready => Phase.Done,
                        RawClipJobStatus.Failed => Phase.Failed,
                        _ => Phase.Processing
                    };

                    if (phase is Phase.Done or Phase.Failed)
                        StopPolling();

                    StateHasChanged();
                });
            }
            finally
            {
                Interlocked.Exchange(ref _pollInProgress, 0);
            }
        }, null, TimeSpan.FromSeconds(1), TimeSpan.FromSeconds(1));
    }

    private void StopPolling()
    {
        pollingTimer?.Dispose();
        pollingTimer = null;
    }

    private void Reset()
    {
        StopPolling();
        Interlocked.Exchange(ref _pollInProgress, 0);
        selectedFile = null;
        currentJob = null;
        selectedClipIds.Clear();
        exportFormat = "vertical";
        errorMessage = string.Empty;
        phase = Phase.Idle;
    }

    private void DeleteJob()
    {
        if (currentJob == null) return;
        RawClipService.DeleteJob(currentJob.Id);
        Reset();
    }

    private async Task Retry()
    {
        if (currentJob == null) return;
        var retried = await RawClipService.RetryJobAsync(currentJob.Id, GetCurrentUserId());
        if (!retried)
        {
            errorMessage = "Retry failed. Please upload again.";
            return;
        }

        phase = Phase.Processing;
        StopPolling();
        StartPolling();
    }

    private void GoBack() => NavigationManager.NavigateTo("/");

    public void Dispose() => StopPolling();

    private string GetCurrentUserId()
    {
        return UserIdentityResolver.ResolveFromContextOrFallback(HttpContextAccessor.HttpContext);
    }

    private void SyncSelectedClips()
    {
        if (currentJob == null) return;

        var validIds = currentJob.Clips.Select(c => c.Id).ToHashSet(StringComparer.Ordinal);
        selectedClipIds.RemoveWhere(id => !validIds.Contains(id));

        if (selectedClipIds.Count == 0)
        {
            foreach (var clip in currentJob.Clips)
                selectedClipIds.Add(clip.Id);
        }
    }

    private bool IsClipSelected(RawClip clip) => selectedClipIds.Contains(clip.Id);

    private void SetClipSelection(RawClip clip, bool selected)
    {
        if (selected)
            selectedClipIds.Add(clip.Id);
        else
            selectedClipIds.Remove(clip.Id);
    }

    private void SelectAllClips()
    {
        if (currentJob == null) return;
        foreach (var clip in currentJob.Clips)
            selectedClipIds.Add(clip.Id);
    }

    private void ClearSelectedClips() => selectedClipIds.Clear();

    private int GetSelectedClipCount()
    {
        if (currentJob == null) return 0;
        return currentJob.Clips.Count(c => selectedClipIds.Contains(c.Id));
    }

    private bool HasSelectedClips() => GetSelectedClipCount() > 0;

    private string GetSelectedClipNumbersCsv()
    {
        if (currentJob == null) return string.Empty;
        return string.Join(",",
            currentJob.Clips
                .Where(c => selectedClipIds.Contains(c.Id))
                .OrderBy(c => c.ClipNumber)
                .Select(c => c.ClipNumber));
    }

    private string GetIndividualDownloadUrl(RawClip clip) =>
        $"/api/jobs/{clip.JobId}/clips/{clip.ClipNumber}/export?format={exportFormat}";

    private string GetSelectedDownloadUrl()
    {
        if (currentJob == null) return string.Empty;
        return $"/api/jobs/{currentJob.Id}/export?format={exportFormat}&clipNumbers={GetSelectedClipNumbersCsv()}";
    }

    private string GetExportAspectLabel() => exportFormat == "square" ? "1x1" : "9x16";
    private string GetExportFormatLabel() => exportFormat == "square" ? "Square (1:1)" : "Vertical (9:16)";

    private string GetExportFileName(RawClip clip) =>
        $"{GetSourceBaseName()}-clip-{clip.ClipNumber:D2}-{GetExportAspectLabel()}.mp4";

    private string GetSelectedZipFileName() =>
        $"{GetSourceBaseName()}-selected-{GetExportAspectLabel()}.zip";

    private string GetSourceBaseName()
    {
        var sourceName = currentJob?.SourceFileName ?? "clips";
        var baseName = Path.GetFileNameWithoutExtension(sourceName);
        if (string.IsNullOrWhiteSpace(baseName))
            baseName = "clips";

        var invalidChars = Path.GetInvalidFileNameChars();
        var safeChars = baseName
            .Select(ch => invalidChars.Contains(ch) ? '-' : ch)
            .ToArray();

        var sanitized = new string(safeChars).Trim('-', '.', ' ');
        return string.IsNullOrWhiteSpace(sanitized) ? "clips" : sanitized;
    }

    // ── Formatting helpers ──────────────────────────────────────────────────

    private static string FormatFileSize(long bytes)
    {
        if (bytes >= 1024 * 1024) return $"{bytes / (1024.0 * 1024):F1} MB";
        if (bytes >= 1024) return $"{bytes / 1024.0:F1} KB";
        return $"{bytes} B";
    }

    private static string FormatDuration(double seconds)
    {
        var ts = TimeSpan.FromSeconds(seconds);
        if (ts.TotalHours >= 1) return $"{(int)ts.TotalHours}h {ts.Minutes}m {ts.Seconds}s";
        if (ts.TotalMinutes >= 1) return $"{(int)ts.TotalMinutes}m {ts.Seconds}s";
        return $"{ts.Seconds}s";
    }

    private static string FormatTime(double seconds)
    {
        var ts = TimeSpan.FromSeconds(seconds);
        return ts.TotalHours >= 1
            ? ts.ToString(@"h\:mm\:ss")
            : ts.ToString(@"m\:ss");
    }
}
