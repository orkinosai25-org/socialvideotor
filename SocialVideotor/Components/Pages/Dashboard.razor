@page "/"
@using SocialVideotor.Models
@using SocialVideotor.Services
@inject IProjectService ProjectService
@inject IRawClipService RawClipService
@inject NavigationManager NavigationManager
@rendermode InteractiveServer

<PageTitle>SocialVideotor - Dashboard</PageTitle>

<FluentStack Orientation="Orientation.Vertical" Style="gap: 24px;">
    <FluentStack Orientation="Orientation.Horizontal" VerticalAlignment="VerticalAlignment.Center" Style="justify-content: space-between; width: 100%;">
        <div style="display: flex; align-items: center; gap: 16px;">
            <img src="logo.svg" alt="SocialVideotor" style="width: 72px; height: auto;" />
            <div>
                <h1 style="margin: 0; font-size: 2rem; font-weight: 800;">
                    <span style="color: var(--brand-indigo);">Social</span><span style="color: var(--brand-violet);">Videotor</span>
                </h1>
                <p style="margin: 4px 0 0 0; color: #6B7280; font-size: 0.95rem;">AI-powered social media video clips</p>
            </div>
        </div>
        <FluentButton Appearance="Appearance.Accent" OnClick="@CreateNewProject">
            <FluentIcon Value="@(new Icons.Regular.Size20.Add())" Slot="start" />
            New Project
        </FluentButton>
        <FluentButton Appearance="Appearance.Outline" OnClick="@GoToRawClips">
            <FluentIcon Value="@(new Icons.Regular.Size20.Cut())" Slot="start" />
            Raw Clips
        </FluentButton>
    </FluentStack>

    @if (!projects.Any())
    {
        <FluentCard Style="padding: 48px; text-align: center; width: 100%;">
            <FluentIcon Value="@(new Icons.Regular.Size48.Video())" Style="color: var(--accent-fill-rest);" />
            <h3>No projects yet</h3>
            <p style="color: var(--neutral-foreground-hint);">Create your first social media video project</p>
            <FluentStack Orientation="Orientation.Horizontal" Style="gap: 12px; justify-content: center; flex-wrap: wrap;">
                <FluentButton Appearance="Appearance.Accent" OnClick="@CreateNewProject">Get Started</FluentButton>
                <FluentButton Appearance="Appearance.Outline" OnClick="@GoToRawClips">
                    <FluentIcon Value="@(new Icons.Regular.Size20.Cut())" Slot="start" />
                    Generate Raw Clips
                </FluentButton>
            </FluentStack>
        </FluentCard>
    }
    else
    {
        <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: 16px; width: 100%;">
            @foreach (var project in projects)
            {
                <FluentCard Style="padding: 20px; cursor: pointer;" @onclick="@(() => OpenProject(project.Id))">
                    <FluentStack Orientation="Orientation.Vertical" Style="gap: 12px;">
                        <FluentStack Orientation="Orientation.Horizontal" VerticalAlignment="VerticalAlignment.Center" Style="justify-content: space-between;">
                            <h3 style="margin: 0; font-size: 1.1rem;">@project.Name</h3>
                            <FluentBadge Appearance="@GetStatusAppearance(project.Status)">@project.Status</FluentBadge>
                        </FluentStack>

                        <FluentStack Orientation="Orientation.Horizontal" Style="gap: 8px; flex-wrap: wrap;">
                            @foreach (var platform in project.TargetPlatforms)
                            {
                                <FluentBadge>@GetPlatformEmoji(platform) @platform</FluentBadge>
                            }
                        </FluentStack>

                        <FluentStack Orientation="Orientation.Horizontal" Style="justify-content: space-between;">
                            <span style="color: var(--neutral-foreground-hint); font-size: 0.85rem;">
                                @project.Clips.Count clip(s) · @FormatDuration(project.VideoDuration)
                            </span>
                            <span style="color: var(--neutral-foreground-hint); font-size: 0.85rem;">
                                @project.CreatedAt.ToString("MMM dd")
                            </span>
                        </FluentStack>

                        <FluentStack Orientation="Orientation.Horizontal" Style="gap: 8px; justify-content: flex-end;">
                            <FluentButton Appearance="Appearance.Outline" OnClick="@(() => OpenProject(project.Id))">
                                Open
                            </FluentButton>
                            <FluentButton Appearance="Appearance.Outline" OnClick="@((e) => DeleteProject(project.Id, e))">
                                Delete
                            </FluentButton>
                        </FluentStack>
                    </FluentStack>
                </FluentCard>
            }
        </div>
    }
</FluentStack>

<FluentCard Style="padding: 20px; width: 100%; margin-top: 16px;">
    <FluentStack Orientation="Orientation.Vertical" Style="gap: 12px;">
        <FluentStack Orientation="Orientation.Horizontal" VerticalAlignment="VerticalAlignment.Center" Style="justify-content: space-between;">
            <h3 style="margin: 0;">Video Processing Jobs</h3>
            <FluentButton Appearance="Appearance.Outline" OnClick="@GoToRawClips">Upload Video</FluentButton>
        </FluentStack>
        @if (!rawClipJobs.Any())
        {
            <span style="color: var(--neutral-foreground-hint); font-size: 0.9rem;">No uploads yet.</span>
        }
        else
        {
            <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); gap: 12px;">
                @foreach (var job in rawClipJobs)
                {
                    <FluentCard Style="padding: 12px;">
                        <FluentStack Orientation="Orientation.Vertical" Style="gap: 6px;">
                            <strong>@job.SourceFileName</strong>
                            <FluentBadge Appearance="@GetRawClipStatusAppearance(job.Status)">@job.Status</FluentBadge>
                            <span style="font-size: 0.8rem; color: var(--neutral-foreground-hint);">@job.StatusMessage</span>
                            <span style="font-size: 0.8rem; color: var(--neutral-foreground-hint);">@job.Clips.Count clip(s)</span>
                        </FluentStack>
                    </FluentCard>
                }
            </div>
        }
    </FluentStack>
</FluentCard>

@code {
    private List<VideoProject> projects = new();
    private List<RawClipJob> rawClipJobs = new();

    protected override void OnInitialized()
    {
        LoadProjects();
    }

    private void LoadProjects()
    {
        projects = ProjectService.GetAllProjects().ToList();
        rawClipJobs = RawClipService.GetAllJobs("anonymous").Take(8).ToList();
    }

    private void CreateNewProject()
    {
        NavigationManager.NavigateTo("/new-project");
    }

    private void GoToRawClips()
    {
        NavigationManager.NavigateTo("/upload-video");
    }

    private void OpenProject(string id)
    {
        NavigationManager.NavigateTo($"/video-analysis/{id}");
    }

    private void DeleteProject(string id, MouseEventArgs e)
    {
        ProjectService.DeleteProject(id);
        LoadProjects();
    }

    private Appearance GetStatusAppearance(ProjectStatus status) => status switch
    {
        ProjectStatus.Ready => Appearance.Accent,
        ProjectStatus.Analyzing => Appearance.Neutral,
        ProjectStatus.Completed => Appearance.Accent,
        _ => Appearance.Neutral
    };

    private Appearance GetRawClipStatusAppearance(RawClipJobStatus status) => status switch
    {
        RawClipJobStatus.Ready => Appearance.Accent,
        RawClipJobStatus.Failed => Appearance.Neutral,
        _ => Appearance.Neutral
    };

    private string GetPlatformEmoji(SocialPlatform platform) => platform switch
    {
        SocialPlatform.Facebook => "📘",
        SocialPlatform.Instagram => "📸",
        SocialPlatform.YouTube => "▶️",
        SocialPlatform.TikTok => "🎵",
        _ => "📱"
    };

    private string FormatDuration(double seconds)
    {
        var ts = TimeSpan.FromSeconds(seconds);
        return ts.TotalHours >= 1 ? $"{(int)ts.TotalHours}h {ts.Minutes}m" : $"{ts.Minutes}m {ts.Seconds}s";
    }
}
